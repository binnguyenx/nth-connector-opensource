# Mẫu cho máy local — copy thành `.env.local` rồi điền giá trị thật:
#   PowerShell:  Copy-Item .env.local.example .env.local
#
# Vite đọc `.env` trước, sau đó `.env.local` (cùng tên biến thì `.env.local` thắng).
# Hai file đều đã trong `.gitignore` — không commit lên GitHub.

# --- Bắt buộc cho `npm run dev` ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# --- Bắt buộc (thumbnail / upload từ trình duyệt) ---
# Cloud name = Product Environment ID trên Cloudinary (vd: dwyfbgc8d)
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-upload-preset-name

# --- Chỉ đặt trên Supabase Dashboard → Edge Functions → Secrets (KHÔNG cần trong .env.local trừ khi bạn có tool đọc) ---
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# DEFAULT_IMAGE_URL=
# SHEET_SYNC_SECRET=
